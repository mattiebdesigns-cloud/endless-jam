# Copy this file to .env for local development
# On Render, set these as environment variables in the dashboard

# Paste the entire contents of your service account JSON key file as a single-line string
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"radio-reader@YOUR_PROJECT.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# The Google Drive folder ID (from the URL of the shared folder)
DRIVE_FOLDER_ID=0B7pTsV_yQbEXVkRVWEVSZkZJQjg

# The resource key for the shared folder (from the URL ?resourcekey= parameter)
DRIVE_RESOURCE_KEY=0-0IKAUcYG-xFxff_GxKY_NQ

# Allowed CORS origin (set to your website URL in production)
CORS_ORIGIN=https://cedarwater.net
